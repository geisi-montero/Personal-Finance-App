<UserControl x:Class="FinanzasApp.Views.BudgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FinanzasApp.Models"
             Background="{StaticResource ContentBgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ===== COLUMNA IZQUIERDA: lista de presupuestos ===== -->
        <Grid Grid.Column="0" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header + navegacion de mes -->
            <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20,14" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="1"/>
                </Border.Effect>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddBudgetCommand}" Content="+ Nuevo Presupuesto" Padding="14,8"/>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding PrevMonthCommand}"
                                Content="&#x2190;" Padding="10,6" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding CurrentMonthLabel}" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"
                                   MinWidth="160" TextAlignment="Center"/>
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding NextMonthCommand}"
                                Content="&#x2192;" Padding="10,6" Margin="8,0,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Tarjetas de presupuesto -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Estado vacío -->
                    <Border Visibility="{Binding Budgets.Count, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            Style="{StaticResource CardStyle}" Padding="40">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📊" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="Sin presupuestos para este mes" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Crea un presupuesto para controlar tus gastos" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Budgets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Budget}">
                                <Border Style="{StaticResource CardStyle}" Width="260" Margin="0,0,16,16">
                                    <StackPanel>
                                        <!-- Cabecera tarjeta -->
                                        <DockPanel Margin="0,0,0,12">
                                            <Button DockPanel.Dock="Right" Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Content="✕" Padding="6,3" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding CategoryIcon}" FontSize="22"
                                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding CategoryName}" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <!-- Montos -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="Gastado: RD$ "/>
                                                <Run Text="{Binding SpentAmount, StringFormat={}{0:N2}}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" FontSize="12" FontWeight="Bold"
                                                       Foreground="{Binding StatusColor, Converter={StaticResource HexColorToBrushConverter}}">
                                                <Run Text="{Binding PercentageText}"/>
                                                <Run Text="%"/>
                                            </TextBlock>
                                        </Grid>

                                        <!-- Barra de progreso sin binding en Width -->
                                        <Border Height="10" Background="#F1F5F9" CornerRadius="5" ClipToBounds="True">
                                            <Border HorizontalAlignment="Left" Height="10" CornerRadius="5"
                                                    Background="{Binding StatusColor, Converter={StaticResource HexColorToBrushConverter}}"
                                                    Width="{Binding ProgressWidth}"/>
                                        </Border>

                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,8,0,0" HorizontalAlignment="Right">
                                            <Run Text="Límite: RD$ "/>
                                            <Run Text="{Binding LimitAmount, StringFormat={}{0:N2}}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ===== COLUMNA DERECHA: panel formulario ===== -->
        <Border Grid.Column="1"
                Visibility="{Binding ShowForm, Converter={StaticResource BoolToVisibilityConverter}}"
                Width="320" Background="White">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.10" BlurRadius="20" ShadowDepth="-2"/>
            </Border.Effect>
            <StackPanel Margin="24">

                <!-- Encabezado -->
                <DockPanel Margin="0,0,0,24">
                    <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}"
                            Content="✕" Padding="8,4" FontSize="13"/>
                    <StackPanel>
                        <TextBlock Text="Nuevo Presupuesto" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Límite de gasto mensual" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </DockPanel>

                <!-- Categoría -->
                <TextBlock Text="CATEGORÍA" Style="{StaticResource FormLabelStyle}"/>
                <ComboBox Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,16"
                          ItemsSource="{Binding ExpenseCategories}"
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="Name"/>

                <!-- Límite -->
                <TextBlock Text="LÍMITE MENSUAL (RD$)" Style="{StaticResource FormLabelStyle}"/>
                <TextBox Style="{StaticResource InputStyle}" Margin="0,0,0,24"
                         Text="{Binding LimitAmount, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Error -->
                <Border Background="#FEF2F2" CornerRadius="8" Padding="12,8" Margin="0,0,0,16"
                        Visibility="{Binding FormMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding FormMessage}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Botones -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}" Content="Cancelar" Padding="0,10"/>
                    <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}" Content="💾  Guardar" Padding="0,10"/>
                </Grid>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
