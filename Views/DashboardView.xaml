<UserControl x:Class="FinanzasApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FinanzasApp.Models"
             Background="{StaticResource ContentBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- KPI Cards Row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Income Card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Background="#DCFCE7" CornerRadius="8" Padding="8,6" Margin="0,0,10,0">
                                <TextBlock Text="&#x2191;" FontSize="16" Foreground="#10B981" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Ingresos del Mes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" FontSize="26" FontWeight="Bold" Foreground="#10B981">
                            <Run Text="RD$"/>
                            <Run Text="{Binding TotalIncome, Converter={StaticResource AmountFormatConverter}}"/>
                        </TextBlock>
                        <TextBlock Grid.Row="4" Text="{Binding CurrentMonthYear}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>

                <!-- Expense Card -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Background="#FEE2E2" CornerRadius="8" Padding="8,6" Margin="0,0,10,0">
                                <TextBlock Text="&#x2193;" FontSize="16" Foreground="#EF4444" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Gastos del Mes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" FontSize="26" FontWeight="Bold" Foreground="#EF4444">
                            <Run Text="RD$"/>
                            <Run Text="{Binding TotalExpenses, Converter={StaticResource AmountFormatConverter}}"/>
                        </TextBlock>
                        <TextBlock Grid.Row="4" Text="{Binding CurrentMonthYear}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>

                <!-- Balance Card -->
                <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Background="#EDE9FE" CornerRadius="8" Padding="8,6" Margin="0,0,10,0">
                                <TextBlock Text="=" FontSize="16" Foreground="#6366F1" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Balance Neto" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" FontSize="26" FontWeight="Bold"
                                   Foreground="{Binding Balance, Converter={StaticResource BalanceColorConverter}}">
                            <Run Text="RD$"/>
                            <Run Text="{Binding Balance, Converter={StaticResource AmountFormatConverter}}"/>
                        </TextBlock>
                        <TextBlock Grid.Row="4" Text="Disponible este mes" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Charts Row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Bar Chart -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Ingresos vs Gastos" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="Ultimos 6 meses" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="12" Height="12" Background="#10B981" CornerRadius="3" Margin="0,0,6,0"/>
                            <TextBlock Text="Ingresos" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                            <Border Width="12" Height="12" Background="#EF4444" CornerRadius="3" Margin="0,0,6,0"/>
                            <TextBlock Text="Gastos" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Bars -->
                        <ItemsControl ItemsSource="{Binding MonthlyBars}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6,0" Width="48">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Height="130">
                                            <Border Width="16" Height="{Binding IncomeHeight}" Background="#10B981"
                                                    CornerRadius="3,3,0,0" VerticalAlignment="Bottom" Margin="0,0,2,0"/>
                                            <Border Width="16" Height="{Binding ExpensesHeight}" Background="#EF4444"
                                                    CornerRadius="3,3,0,0" VerticalAlignment="Bottom"/>
                                        </StackPanel>
                                        <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,4"/>
                                        <TextBlock Text="{Binding Month}" FontSize="10" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Top Categories Pie-like -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Top Categorias" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="Mayor gasto este mes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                        <ItemsControl ItemsSource="{Binding TopCategories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:CategoryStat}">
                                    <StackPanel Margin="0,0,0,12">
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock DockPanel.Dock="Left" Text="{Binding Icon}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                                                <Run Text="{Binding Percentage, StringFormat={}{0:N0}}"/>
                                                <Run Text="%"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding CategoryName}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <Border Height="6" Background="#F1F5F9" CornerRadius="3">
                                            <Border HorizontalAlignment="Left" Height="6" CornerRadius="3"
                                                    Background="{Binding Color, Converter={StaticResource HexColorToBrushConverter}}"
                                                    Width="{Binding Percentage, Converter={StaticResource PercentageToWidthConverter}, ConverterParameter=160, Mode=OneWay}"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Sin gastos registrados este mes" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,20,0,0"
                                   Visibility="{Binding TopCategories.Count, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Transactions -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock DockPanel.Dock="Left" Text="Transacciones Recientes" Style="{StaticResource SectionTitleStyle}"/>
                    </DockPanel>

                    <!-- Header -->
                    <Border Background="#F8FAFC" CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DESCRIPCION" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="CATEGORIA" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="FECHA" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="MONTO" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding RecentTransactions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Transaction}">
                                <Border Padding="12,10" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0"
                                                    Background="{Binding Type, Converter={StaticResource TransactionTypeToColorConverter}}">
                                                <TextBlock Text="{Binding CategoryIcon}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Notes}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding CategoryName}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Date, StringFormat={}{0:dd/MM/yy}}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="{Binding Type, Converter={StaticResource TransactionTypeToColorConverter}}">
                                            <Run Text="{Binding Type, Converter={StaticResource TransactionTypeToSignConverter}}"/>
                                            <Run Text="RD$"/>
                                            <Run Text="{Binding Amount, Converter={StaticResource AmountFormatConverter}}"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No hay transacciones registradas" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,24"
                               Visibility="{Binding RecentTransactions.Count, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
