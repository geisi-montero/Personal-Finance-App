<UserControl x:Class="FinanzasApp.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FinanzasApp.Models"
             Background="{StaticResource ContentBgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Panel lateral del formulario -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ===== COLUMNA IZQUIERDA: lista + filtros ===== -->
        <Grid Grid.Column="0" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra de filtros / botón Nueva -->
            <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="1"/>
                </Border.Effect>
                <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddTransactionCommand}"
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="18" FontWeight="Bold" Margin="0,0,6,0"/>
                            <TextBlock Text="Nueva Transacción" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <WrapPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <TextBlock Text="Tipo:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Style="{StaticResource ComboBoxStyle}" Width="100"
                                      ItemsSource="{Binding TypeOptions}"
                                      SelectedItem="{Binding SelectedFilterType}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <TextBlock Text="Desde:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <DatePicker Style="{StaticResource DatePickerStyle}" Width="120"
                                        SelectedDate="{Binding FilterFrom}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <TextBlock Text="Hasta:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <DatePicker Style="{StaticResource DatePickerStyle}" Width="120"
                                        SelectedDate="{Binding FilterTo}"/>
                        </StackPanel>
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding ClearFiltersCommand}"
                                Content="Limpiar" Padding="10,7"/>
                    </WrapPanel>
                </DockPanel>
            </Border>

            <!-- Lista de transacciones -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="1"/>
                </Border.Effect>
                <DockPanel>
                    <!-- Encabezado de columnas -->
                    <Border DockPanel.Dock="Top" Background="#F8FAFC" CornerRadius="12,12,0,0" Padding="20,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TRANSACCIÓN" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="CATEGORÍA" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="FECHA" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="MONTO" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Mensaje vacío -->
                    <TextBlock DockPanel.Dock="Bottom"
                               Text="No hay transacciones registradas."
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,32"
                               Visibility="{Binding Transactions.Count, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Transactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:Transaction}">
                                    <Border Padding="20,10" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icono + Título -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0"
                                                        Background="{Binding Type, Converter={StaticResource TransactionTypeToColorConverter}}">
                                                    <TextBlock Text="{Binding CategoryIcon}" FontSize="16"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Notes}" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{Binding CategoryName}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Date, StringFormat={}{0:dd/MM/yy}}"
                                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="{Binding Type, Converter={StaticResource TransactionTypeToColorConverter}}">
                                                <Run Text="{Binding Type, Converter={StaticResource TransactionTypeToSignConverter}}"/>
                                                <Run Text="RD$ "/>
                                                <Run Text="{Binding Amount, Converter={StaticResource AmountFormatConverter}}"/>
                                            </TextBlock>

                                            <Button Grid.Column="4" Style="{StaticResource DangerButton}"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Content="✕" Padding="6,4" FontSize="11"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===== COLUMNA DERECHA: panel formulario ===== -->
        <Border Grid.Column="1"
                Visibility="{Binding ShowForm, Converter={StaticResource BoolToVisibilityConverter}}"
                Width="320" Background="White" Margin="0,0,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.10" BlurRadius="20" ShadowDepth="-2"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">

                    <!-- Encabezado del formulario -->
                    <DockPanel Margin="0,0,0,20">
                        <Button DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}"
                                Content="✕" Padding="8,4" FontSize="13"/>
                        <StackPanel>
                            <TextBlock Text="Nueva Transacción" FontSize="17" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Completa los datos" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Tipo: Ingreso / Gasto -->
                    <TextBlock Text="TIPO" Style="{StaticResource FormLabelStyle}"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Botón Ingreso -->
                        <Border Grid.Column="0" CornerRadius="8" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TransactionType}" Value="Ingreso">
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                            <Setter Property="BorderBrush" Value="#10B981"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding SetTypeIncomeCommand}"/>
                            </Border.InputBindings>
                            <StackPanel HorizontalAlignment="Center" Margin="0,12">
                                <TextBlock Text="↑" FontSize="20" HorizontalAlignment="Center" Foreground="#10B981"/>
                                <TextBlock Text="Ingreso" FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Botón Gasto -->
                        <Border Grid.Column="2" CornerRadius="8" Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TransactionType}" Value="Gasto">
                                            <Setter Property="Background" Value="#FEE2E2"/>
                                            <Setter Property="BorderBrush" Value="#EF4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding SetTypeExpenseCommand}"/>
                            </Border.InputBindings>
                            <StackPanel HorizontalAlignment="Center" Margin="0,12">
                                <TextBlock Text="↓" FontSize="20" HorizontalAlignment="Center" Foreground="#EF4444"/>
                                <TextBlock Text="Gasto" FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Título -->
                    <TextBlock Text="TÍTULO" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Style="{StaticResource InputStyle}" Margin="0,0,0,14"
                             Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Monto -->
                    <TextBlock Text="MONTO (RD$)" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Style="{StaticResource InputStyle}" Margin="0,0,0,14"
                             Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Fecha -->
                    <TextBlock Text="FECHA" Style="{StaticResource FormLabelStyle}"/>
                    <DatePicker Style="{StaticResource DatePickerStyle}" Margin="0,0,0,14"
                                SelectedDate="{Binding Date}"/>

                    <!-- Categoría -->
                    <TextBlock Text="CATEGORÍA" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,14"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              DisplayMemberPath="Name"/>

                    <!-- Notas -->
                    <TextBlock Text="NOTAS (opcional)" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Style="{StaticResource InputStyle}" Margin="0,0,0,20"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             Height="64" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <!-- Error message -->
                    <Border Background="#FEF2F2" CornerRadius="8" Padding="12,8" Margin="0,0,0,14"
                            Visibility="{Binding FormMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding FormMessage}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Botones Cancelar / Guardar -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                                Command="{Binding CancelCommand}" Content="Cancelar" Padding="0,10"/>
                        <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" Content="💾  Guardar" Padding="0,10"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
